{
	"name": "MetPen AI Lab",
  	"build": {
    	"context": "..",
    	"dockerfile": "./Dockerfile",
    	"options": [
      		"--build-arg", "BUILDKIT_INLINE_CACHE=1"
    	]
	},
	"runArgs": [
    	"--init",
    	"--network=host"
	],
	"workspaceFolder": "/workspaces/metpen-ai-lab",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/metpen-ai-lab,type=bind,consistency=cached",

	"remoteUser": "root"
}